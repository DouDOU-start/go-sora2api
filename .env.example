APP_PORT=8686

POSTGRES_DB=sora2api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ADMIN_USER=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=

DB_LOG_LEVEL=warn
AUTO_MIGRATE=true

# 应用访问 Sora/OpenAI 时使用的代理，支持 http:// https:// socks5://
# 优先级高于后台“系统设置”里的 proxy_url
# Linux Docker 下如代理在宿主机，可写成 http://host.docker.internal:端口
APP_PROXY_URL=

# Docker 构建和容器运行时的标准代理环境变量
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=127.0.0.1,localhost,postgres
